# Copier ce fichier en .env.local et renseigner les valeurs
# Ne jamais commiter le fichier .env.local

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=votre_cle_publishable_supabase
VITE_SUPABASE_PROJECT_ID=votre_project_id

# --- Edge Functions (secrets Supabase) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=votre@email.fr
SENDGRID_FROM_NAME=TrustBuild IA
FROM_EMAIL=votre@email.fr
INSEE_API_KEY=votre_cle_insee

# --- Supabase interne (auto-injectées dans les Edge Functions) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
